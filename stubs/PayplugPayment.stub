<?php

namespace Payplug\Resource;

class Payment
{
    /** @var string|null */
    public $id;

    /** @var int */
    public $amount;

    /** @var int */
    public $amount_refunded;

    /** @var int|null */
    public $refundable_after;

    /** @var int|null */
    public $refundable_until;

    /** @var mixed|null */
    public $failure;

    /** @var bool|null */
    public $is_paid;
}
