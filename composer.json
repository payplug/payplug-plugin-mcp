{
  "name": "payplug/payplug-plugin-mcp",
  "description": "Module pour l'intégration MCP Payplug.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Payplug",
      "email": "support@payplug.com"
    }
  ],
  "require": {
    "php": "^7.4",
    "payplug/payplug-php": "^4.0"
  },
  "require-dev": {
    "captainhook/captainhook": "^5.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "mockery/mockery": "^1.3",
    "phpstan/phpstan": "^2.2.0",
    "phpstan/phpstan-mockery": "*",
    "phpstan/phpstan-phpunit": "*",
    "phpunit/phpunit": "^9.5"
  },
  "autoload": {
    "psr-4": {
      "PayPlugPluginMcp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PayPlugPluginMcp\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-install-cmd": "vendor/bin/captainhook install --force",
    "post-update-cmd": "vendor/bin/captainhook install --force",
    "test": "vendor/bin/phpunit tests",
    "stan": "vendor/bin/phpstan analyse --configuration=phpstan.neon",
    "cs-lint": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff",
    "cs-fix": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php"
  },
  "config": {
    "sort-packages": true
  }
}
